{
  "version": "segment_manifest_v1",
  "description": "Part 1 input schema for segment-level keyframe inference before Colab reconstruction.",
  "constraints": {
    "segment_count": "1-5",
    "segment_duration_seconds": 0.5,
    "keyframes_per_segment": "1-3"
  },
  "example": {
    "reference_video_path": "C:/absolute/path/demo.mp4",
    "target_duration_seconds": 1.5,
    "segments": [
      {
        "segment_id": "seg_01",
        "start_s": 0.0,
        "end_s": 0.5,
        "keyframes": [
          "C:/absolute/path/seg_01_frame_01.png",
          "C:/absolute/path/seg_01_frame_02.png"
        ],
        "notes": "",
        "event_name": "optional",
        "context": "optional"
      }
    ]
  }
}
