String serialBuffer;

void writeRegister(uint8_t reg, uint8_t value) {
  Wire.beginTransmission(DRV2605_ADDR);
  Wire.write(reg);
  Wire.write(value);
  Wire.endTransmission();
}

uint8_t readRegister(uint8_t reg) {
  Wire.beginTransmission(DRV2605_ADDR);
  Wire.write(reg);
  Wire.endTransmission(false);
  Wire.requestFrom(static_cast<int>(DRV2605_ADDR), 1);

  if (Wire.available()) {
    return Wire.read();
  }

  return 0;
}

void stopMotor() {
  writeRegister(REG_RTP_INPUT, 0);
  delay(5);
  writeRegister(REG_MODE, MODE_INTERNAL_TRIGGER);
}

void setRealtimeAmplitude(uint8_t amplitude) {
  writeRegister(REG_RTP_INPUT, amplitude);
}

void enterRtpMode() {
  writeRegister(REG_MODE, MODE_REALTIME_PLAYBACK);
}

void initDrv2605() {
  delay(10);
  writeRegister(REG_MODE, MODE_INTERNAL_TRIGGER);
  delay(10);

  // Clear the actuator type bit so the driver uses ERM behavior.
  uint8_t feedback = readRegister(REG_FEEDBACK);
  feedback &= ~FEEDBACK_ACTUATOR_TYPE_BIT;
  writeRegister(REG_FEEDBACK, feedback);

  // Use unidirectional RTP input: 0 = no drive, 255 = maximum drive.
  uint8_t control2 = readRegister(REG_CONTROL2);
  control2 &= ~CONTROL2_BIDIR_INPUT;
  writeRegister(REG_CONTROL2, control2);

  // CONTROL3:
  // - DATA_FORMAT_RTP = 1: unsigned RTP samples, matching uint8_t arrays.
  // - ERM_OPEN_LOOP = 1: stable direct ERM drive from RTP amplitude.
  uint8_t control3 = readRegister(REG_CONTROL3);
  control3 |= CONTROL3_DATA_FORMAT_RTP | CONTROL3_ERM_OPEN_LOOP;
  writeRegister(REG_CONTROL3, control3);

  stopMotor();
}

uint16_t playbackSampleLimit(const WaveformDefinition &waveform) {
  if (waveform.sampleIntervalMs == 0) {
    return 0;
  }

  const uint32_t maxSamples = MAX_STIMULUS_DURATION_MS / waveform.sampleIntervalMs;
  if (maxSamples == 0) {
    return 0;
  }

  if (waveform.sampleCount < maxSamples) {
    return waveform.sampleCount;
  }

  return static_cast<uint16_t>(maxSamples);
}

bool playAnonymousStimulus(uint8_t anonymousId) {
  if (anonymousId < 1 || anonymousId > 60) {
    Serial.println("ERR:INVALID_ID");
    return false;
  }

  const WaveformDefinition &waveform = STIMULI[anonymousId - 1];
  const uint16_t sampleLimit = playbackSampleLimit(waveform);

  if (sampleLimit == 0) {
    Serial.println("ERR:BAD_WAVEFORM");
    return false;
  }

  enterRtpMode();

  for (uint16_t index = 0; index < sampleLimit; index += 1) {
    setRealtimeAmplitude(waveform.samples[index]);
    delay(waveform.sampleIntervalMs);
  }

  stopMotor();
  return true;
}

void processSerialLine(const String &line) {
  if (line.length() == 0) {
    return;
  }

  char *endPtr = nullptr;
  long anonymousId = strtol(line.c_str(), &endPtr, 10);

  if (endPtr == line.c_str() || *endPtr != '\0') {
    Serial.println("ERR:PARSE");
    return;
  }

  if (anonymousId < 1 || anonymousId > 60) {
    Serial.println("ERR:INVALID_ID");
    return;
  }

  if (playAnonymousStimulus(static_cast<uint8_t>(anonymousId))) {
    Serial.print("PLAYED:");
    Serial.println(anonymousId);
  }
}

void setup() {
  Serial.begin(SERIAL_BAUD_RATE);
  Wire.begin(SDA_PIN, SCL_PIN);
  Wire.setClock(400000);
  initDrv2605();
  serialBuffer.reserve(16);
  Serial.println("READY");
}

void loop() {
  while (Serial.available() > 0) {
    char incoming = static_cast<char>(Serial.read());

    if (incoming == '\r') {
      continue;
    }

    if (incoming == '\n') {
      processSerialLine(serialBuffer);
      serialBuffer = "";
      continue;
    }

    serialBuffer += incoming;
  }
}
